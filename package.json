{
  "name": "akkhar-code-patcher",
  "displayName": "Akkhar Code Patcher",
  "description": "Akkhar Orchestration Protocol V2: Surgical Search & Replace.",
  "publisher": "akkhar-labs",
  "author": "Akkhar-Labs",
  "icon": "resources/logo.png",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akkhar-Labs/akkhar-code-patcher.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "surgical",
    "patch",
    "search",
    "replace",
    "ai",
    "orchestration",
    "akkhar"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "akkhar-code-patcher-sidebar",
          "title": "Akkhar Orchestration",
          "icon": "$(search-fuzzy)"
        }
      ]
    },
    "views": {
      "akkhar-code-patcher-sidebar": [
        {
          "type": "webview",
          "id": "akkhar-code-patcher-view",
          "name": "Surgical Replacer"
        }
      ]
    },
    "commands": [
      {
        "command": "akkhar-code-patcher.executePatch",
        "title": "Akkhar: Execute Surgical Patch",
        "category": "Akkhar"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
